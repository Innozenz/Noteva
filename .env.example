# Database
# Sur une base distante (Neon), préciser `sslmode=verify-full` explicitement.
# `sslmode=require` fonctionne, mais pg avertit à chaque démarrage : il le
# traite aujourd'hui comme verify-full et adoptera en v9 la sémantique libpq,
# plus permissive. Écrire le mode voulu fige le comportement actuel — le plus
# strict — et supprime l'avertissement.
DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/mydb?schema=public"

# Better Auth
BETTER_AUTH_SECRET="your-secret-here"
BETTER_AUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Stripe — abonnement des profs (les élèves ne paient rien en ligne)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Tarif de l'abonnement prof. Côté serveur uniquement : le client ne choisit
# jamais son prix.
STRIPE_PRICE_ID="price_..."
# Hérité du boilerplate. NEXT_PUBLIC_STRIPE_PRICE_ID sert encore de repli à
# STRIPE_PRICE_ID, et la clé publique n'est plus utilisée nulle part.
NEXT_PUBLIC_STRIPE_PRICE_ID="price_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Notifications par e-mail (facultatif)
# Sans ces deux variables, les messages sont écrits dans la console : le
# développement reste utilisable et on voit exactement ce qui serait parti.
RESEND_API_KEY=""
NOTIFICATIONS_FROM="Noteva <notifications@votre-domaine.fr>"

# Rappels avant cours — secret attendu par /api/cron/reminders.
# Sans lui la route répond 503 et aucun rappel ne part : une tâche planifiée
# ouverte à tous vaut moins qu'une tâche en panne, qui elle se remarque.
# Appel : curl -H "x-cron-secret: $CRON_SECRET" URL/api/cron/reminders
CRON_SECRET=""

# Next.js
# Sert aussi de racine aux liens contenus dans les e-mails : en production,
# mettre l'URL publique réelle, sinon les liens pointeront vers localhost.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
