# Database
DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/mydb?schema=public"

# Better Auth
BETTER_AUTH_SECRET="your-secret-here"
BETTER_AUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Stripe — abonnement des profs (les élèves ne paient rien en ligne)
STRIPE_API_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Tarif de l'abonnement prof. Côté serveur uniquement : le client ne choisit
# jamais son prix.
STRIPE_PRICE_ID="price_..."
# Hérité du boilerplate. NEXT_PUBLIC_STRIPE_PRICE_ID sert encore de repli à
# STRIPE_PRICE_ID, et la clé publique n'est plus utilisée nulle part.
NEXT_PUBLIC_STRIPE_PRICE_ID="price_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:3000"
